<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="audit_rule_view_list" model="ir.ui.view">
        <field name="name">audit.rule.list</field>
        <field name="model">audit.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="model_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="audit_rule_view_form" model="ir.ui.view">
        <field name="name">audit.rule.form</field>
        <field name="model">audit.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="active" widget="boolean_toggle"/>
                    <group>
                        <field name="name"/>
                        <field name="model_id"/>
                    </group>
                    <field name="field_ids" widget="many2many_tags"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="audit_rule_action" model="ir.actions.act_window">
        <field name="name">Audit Rules</field>
        <field name="res_model">audit.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
